{
  "manifest_version": 3,
  "name": "软考达人做题记录采集",
  "version": "1.1",
  "description": "采集软考达人网站的做题记录并发送到后端接口",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "https://*.ruankaodaren.com/*",
    "https://ruankaodaren.com/*",
    "http://localhost:5002/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.ruankaodaren.com/exam/*", "https://*.ruankaodaren.com/exam", "https://ruankaodaren.com/exam/*", "https://ruankaodaren.com/exam"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "collect-question": {
      "suggested_key": {
        "default": "Ctrl+Shift+C",
        "mac": "Command+Shift+C"
      },
      "description": "采集当前题目"
    }
  }
}